# OpenBao unseal key — generate with: openssl rand -base64 32
# Store the init output (root token + unseal key) in a safe place after first deploy.
OPENBAO_UNSEAL_KEY: 'changeme'

# Cloudflare Dashboard → My Profile → API Tokens
CLOUDFLARE_API_TOKEN: 'changeme'

# Proxmox root or API user password
PROXMOX_PASSWORD: 'changeme'

# Hetzner Cloud → Project → Security → API Tokens
HCLOUD_TOKEN: 'changeme'
